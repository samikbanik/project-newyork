  "rules": {
    "_readme": "Implementation rules — read before coding any new component.",
    "01_darkFirst":       "Dark mode is the only mode for v1. No light-mode variants needed.",
    "02_noHardcoded":     "Never hardcode hex values in component CSS. Always reference a token from this file.",
    "03_borderSubtle":    "Default card border: 1px solid color.border.subtle. Bump to .default on hover, .emphasis on focus.",
    "04_fontStack":       "DM Sans for all UI text. DM Mono only for timestamps, durations, upload stats, tokens, code.",
    "05_accentUsage":     "color.accent is ONLY for: Play buttons, progress bars, logo mark, upload progress. Not for links (use highlight).",
    "06_highlightUsage":  "color.highlight is ONLY for: links, watch-later progress, info states, 'See all' anchors.",
    "07_hoverScale":      "Video cards scale(1.02) on hover. Thumbnail portrait items scale(1.04). Nothing else scales.",
    "08_transitionBase":  "All interactive elements use transition: 220ms ease. Fast actions (button press, badge pop): 150ms.",
    "09_borderRadius":    "Badges = xs(4px). Buttons/inputs = sm(6px). Video thumbs = md(8px). Cards/panels = lg(12px). Chips/pills = full.",
    "10_gridAspect":      "Landscape grid cards always 16:9. Portrait thumbnail rows always 5:7 (140×196px). Never break these ratios.",
    "11_progressBar":     "Progress bars on video cards: 3px height, full-width at bottom of thumbnail, accent color fill.",
    "12_overlayPlay":     "Play button overlay: rgba(0,0,0,0.4) bg on thumb hover, 44px white circle button centred.",
    "13_navHeight":       "Navbar is always 56px tall, glass background, z-index 200.",
    "14_pageGutter":      "Page horizontal gutter: 24px desktop, 16px mobile.",
    "15_skeletonPulse":   "Skeletons use opacity animation 0.5→1→0.5 at 1.5s. Never use a shimmer gradient (breaks dark mode).",
    "16_badgePosition":   "Badges on thumbnail cards: top-left for New/Season, top-right suppressed. Duration: bottom-right always.",
    "17_emptyState":      "Empty states: centred icon (opacity 0.4) + 2-line text + optional CTA. Dashed border, bg-surface bg.",
    "18_uploadProgress":  "Upload: show filename, percent (accent colour), progress bar (accent fill), and '~X min left'.",
    "19_processSteps":    "Processing steps: green dot=done, accent pulsing dot=active, muted dot=pending. Pending rows at 40% opacity.",
    "20_zLayering":       "Follow zIndex tokens exactly. Never use ad-hoc z-index values."
  }
}
